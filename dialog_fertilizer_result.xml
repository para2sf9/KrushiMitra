<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="#E0E0E0"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Precision Dose Calculator"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#1B5E20"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Optimized based on your latest soil report"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="24dp"/>

        <!-- Input Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:hint="Crop"
                android:layout_marginEnd="8dp">

                <AutoCompleteTextView
                    android:id="@+id/spinner_crop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:hint="Acres">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="1.0"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Results Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recommended Nutrients"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:textColor="#888"
            android:layout_marginBottom="16dp"/>

        <!-- Fertilizer Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Urea -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_urea"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/synthetic"
                        app:tint="#D32F2F"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon_urea"
                        android:layout_marginStart="12dp"
                        android:text="Urea (Nitrogen)"
                        android:textColor="#333"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:id="@+id/tv_urea_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="2.5 Bags"
                        android:textColor="#D32F2F"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DAP -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_dap"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/synthetic"
                        app:tint="#F57C00"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon_dap"
                        android:layout_marginStart="12dp"
                        android:text="DAP (Phosphorus)"
                        android:textColor="#333"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:id="@+id/tv_dap_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="1.0 Bag"
                        android:textColor="#F57C00"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MOP -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/icon_mop"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/synthetic"
                        app:tint="#388E3C"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon_mop"
                        android:layout_marginStart="12dp"
                        android:text="MOP (Potassium)"
                        android:textColor="#333"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:id="@+id/tv_mop_qty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Nil"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_to_cart"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Add to Cart (₹1,450)"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:cornerRadius="20dp"
            android:backgroundTint="#2E7D32"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="#D1D1D1" />
<ImageView
    android:id="@+id/farm_type_img"
    android:layout_width="match_parent"
    android:layout_height="170sp"
    android:scaleType="centerCrop"
    android:src="@drawable/farm_types"/>
    <TextView
        android:id="@+id/bsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Farming Type Name"
        android:textColor="#1B5E20"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/bsDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="4dp"
        android:text="Detailed description of the farming method goes here."
        android:textColor="#546E7A"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REGION"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/bsRegion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Punjab"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="#1B5E20"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WATER"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/bsWater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Medium"
                android:textColor="#1B5E20"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROFIT"
                android:textColor="#90A4AE"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/bsProfit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="High"
                android:textColor="#1B5E20"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="#F9FBF9"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#E8F5E9"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="BEST PRACTICES"
                android:textColor="#388E3C"
                android:textSize="11sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/bsTips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="6dp"
                android:text="• Bullet points for tips\n• Clear and concise advice"
                android:textColor="#455A64"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true"
   >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Section with Gradient Scrim -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/imgLeafPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Tool preview" />

            <!-- This view adds a soft shadow at the bottom of the image -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_scrim_bottom" />
        </FrameLayout>

        <!-- Loader positioned over the overlap area -->
        <ProgressBar
            android:id="@+id/progressAnalyse"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginTop="-20dp"
            android:elevation="10dp"
            android:visibility="gone" />

        <!-- Results Card with Negative Margin for Overlap -->
        <androidx.cardview.widget.CardView
            android:id="@+id/scrollResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-30dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Warning: Styled as a soft alert badge -->
                <TextView
                    android:id="@+id/tvWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_badge_orange"
                    android:padding="14dp"
                    android:textColor="#92400E"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:visibility="gone" />

                <!-- Tool Info Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detection_result"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvPlantName"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="#1E293B"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvHealthStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="4dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_badge_orange" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDiseaseName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#2563EB"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />


                <View
                    android:layout_width="match_parent"
                    android:layout_height="1.5dp"
                    android:background="#F1F5F9"
                    android:layout_marginVertical="24dp" />

                <!-- Content Sections -->
                <TextView
                    android:id="@+id/labelDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tool Specifications"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#475569"
                    android:lineSpacingExtra="4dp"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/labelPrevention"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/maintenance_tips"
                    android:textColor="#059669"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutPrevention"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/labelCure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/recommended_actions"
                    android:textColor="#2563EB"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutCure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/labelReference"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Reference Model Image"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/imgHealthyReference"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_rounded_bg"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScanAgain"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/scan_again"
                    app:cornerRadius="16dp"
                    android:backgroundTint="#2E7D32"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>

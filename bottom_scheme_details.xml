<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Scheme Image -->

        <ImageView
            android:id="@+id/bSchemeImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="12dp"/>

        <!-- Scheme Name -->

        <TextView
            android:id="@+id/bSchemeName"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Description -->

        <TextView
            android:id="@+id/bSchemeDesc"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="#555"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Benefits Title -->

        <TextView
            android:text="Benefits"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/bSchemeBenefits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#444"/>

        <!-- Eligibility Title -->

        <TextView
            android:text="Eligibility"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/bSchemeEligibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#444"/>

        <!-- Apply Link -->

        <TextView
            android:id="@+id/bSchemeLink"
            android:text="Apply Here"
            android:textColor="#1E88E5"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>
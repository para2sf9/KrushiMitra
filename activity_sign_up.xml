<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:fitsSystemWindows="true"
    android:background="#F6F8FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="14dp">

        <!-- 🌿 ICON -->

        <!-- TITLE -->

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/profile_picture" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/create_account"
            android:textColor="#044704"
            android:textSize="26sp"
            android:textStyle="bold|italic" />


        <!-- CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:gravity="center_horizontal"
                android:text="@string/smart_farming_starts_here"
                android:textColor="#777"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="30sp"
                android:layout_height="30sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginStart="10dp"
                android:src="@drawable/smart_farm" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- NAME -->
                <EditText
                    android:id="@+id/name"
                    android:hint="@string/full_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/edit_bg"
                    android:padding="14dp"
                    android:maxLines="1"
                    android:layout_marginBottom="12dp"/>

                <!-- EMAIL -->
                <EditText
                    android:id="@+id/email"
                    android:hint="@string/email_address"
                    android:inputType="textEmailAddress"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/edit_bg"
                    android:padding="14dp"
                    android:maxLines="1"
                    android:layout_marginBottom="12dp"/>

                <!-- PHONE -->
                <EditText
                    android:id="@+id/phone"
                    android:hint="@string/phone_number"
                    android:inputType="phone"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:maxLines="1"
                    android:background="@drawable/edit_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <!-- FARMER TYPE DROPDOWN -->
<!--                <Spinner-->
<!--                    android:id="@+id/farmer_type"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="55dp"-->
<!--                    android:background="@drawable/edit_bg"-->
<!--                    android:layout_marginBottom="12dp"/>-->

                <!-- PASSWORD WITH EYE ICON -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/password"
                        android:hint="@string/password"
                        android:inputType="textPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/edit_bg"
                        android:padding="14dp"
                        android:maxLines="1"
                        android:paddingEnd="50dp"/>

                    <ImageView
                        android:id="@+id/togglePassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"/>
                </RelativeLayout>

                <!-- CONFIRM PASSWORD -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/confirm_password"
                        android:hint="@string/confirm_password"
                        android:inputType="textPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/edit_bg"
                        android:padding="14dp"
                        android:maxLines="1"
                        android:paddingEnd="50dp"/>

                    <ImageView
                        android:id="@+id/toggleConfirmPassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_view"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"/>
                </RelativeLayout>

                <!-- 🌾 CROP INTEREST -->
<!--                <TextView-->
<!--                    android:text="Select Crop Interest"-->
<!--                    android:textStyle="bold"-->
<!--                    android:layout_marginBottom="6dp"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"/>-->

<!--                <LinearLayout-->
<!--                    android:orientation="horizontal"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginBottom="16dp">-->

<!--                    <CheckBox android:text="Wheat" -->
<!--                        android:layout_height="wrap_content" -->
<!--                        android:layout_width="match_parent"/>-->
<!--                    <CheckBox android:text="Rice"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_width="match_parent"/>-->
<!--                    <CheckBox android:text="Cotton"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_width="match_parent"/>-->
<!--                </LinearLayout>-->

                <!-- SIGNUP BUTTON -->
                <Button
                    android:id="@+id/signup_btn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:backgroundTint="#146A0A"
                    android:backgroundTintMode="add"
                    android:text="@string/create_account"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

                <!-- OR DIVIDER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDD" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:text="@string/or_text"
                        android:textColor="#888" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#DDD" />
                </LinearLayout>

                <!-- GOOGLE BUTTON -->
                <Button
                    android:id="@+id/google_btn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:backgroundTint="#AD1212"
                    android:text="@string/continue_with_google"
                    android:textAllCaps="false"
                    android:textColor="#fff" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- LOGIN TEXT -->
        <TextView
            android:id="@+id/login_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/already_have_an_account_login"
            android:textColor="#050A3A" />

    </LinearLayout>

</ScrollView>